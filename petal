  <script>
    // Newsletter submit
    function handleSubmit(e) {
      e.preventDefault();
      const input = e.target.querySelector('input');
      if (input.value) {
        input.value = '';
        input.placeholder = 'You\'re in! Check your inbox ✦';
        input.style.borderColor = '#8a9e88';
      }
    }

    // Scroll reveal
    const observer = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          e.target.style.opacity = '1';
          e.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.product-card, .ingredient-item, .ingredient-card').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(20px)';
      el.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
      observer.observe(el);
    });

    // Add to cart button
    document.querySelectorAll('.product-add').forEach(btn => {
      btn.addEventListener('click', function() {
        this.textContent = 'Added ✓';
        this.style.borderColor = '#8a9e88';
        this.style.color = '#5c7259';
        setTimeout(() => {
          this.textContent = 'Add';
          this.style.borderColor = '';
          this.style.color = '';
        }, 2000);
      });
    });
  </script>

