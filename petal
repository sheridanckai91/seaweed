!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>PETAL — Skincare</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --cream: #f7f3ee;
      --warm-white: #faf8f5;
      --sage: #8a9e88;
      --dark-sage: #5c7259;
      --terracotta: #c4734f;
      --warm-brown: #3d2b1f;
      --light-tan: #e8ddd0;
      --mid-tan: #d4c4b0;
      --text-dark: #2a1f18;
      --text-muted: #7a6a5e;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Inter', sans-serif;
      background-color: var(--cream);
      color: var(--text-dark);
      font-size: 15px;
      line-height: 1.6;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 22px 48px;
      background: rgba(247, 243, 238, 0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(212, 196, 176, 0.3);
    }

    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 26px;
      font-weight: 400;
      letter-spacing: 0.2em;
      color: var(--warm-brown);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 36px;
      list-style: none;
    }

    .nav-links a {
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--warm-brown); }

    .nav-cta {
      font-size: 12px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--warm-brown);
      background: none;
      border: 1px solid var(--warm-brown);
      padding: 9px 22px;
      cursor: pointer;
      transition: all 0.25s;
      text-decoration: none;
    }

    .nav-cta:hover {
      background: var(--warm-brown);
      color: var(--cream);
    }

    /* ── HERO ── */
    .hero {
      min-height: 100vh;
      display: grid;
      grid-template-columns: 1fr 1fr;
      padding-top: 80px;
    }

    .hero-left {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 80px 64px 80px 80px;
    }

    .hero-tag {
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 24px;
    }

    .hero-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(52px, 6vw, 88px);
      font-weight: 300;
      line-height: 1.05;
      color: var(--warm-brown);
      margin-bottom: 28px;
    }

    .hero-title em {
      font-style: italic;
      color: var(--terracotta);
    }

    .hero-subtitle {
      font-size: 15px;
      color: var(--text-muted);
      max-width: 380px;
      line-height: 1.75;
      margin-bottom: 44px;
    }

    .btn-primary {
      display: inline-block;
      background: var(--warm-brown);
      color: var(--cream);
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 16px 40px;
      text-decoration: none;
      transition: all 0.25s;
      align-self: flex-start;
    }

    .btn-primary:hover {
      background: var(--terracotta);
    }

    .btn-outline {
      display: inline-block;
      border: 1px solid var(--warm-brown);
      color: var(--warm-brown);
      font-size: 12px;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      padding: 16px 40px;
      text-decoration: none;
      transition: all 0.25s;
    }

    .btn-outline:hover {
      background: var(--warm-brown);
      color: var(--cream);
    }

    .hero-buttons { display: flex; gap: 16px; flex-wrap: wrap; }

    .hero-right {
      background: var(--light-tan);
      position: relative;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .hero-illustration {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 60px;
    }

    /* Decorative botanical SVG element */
    .hero-orb {
      width: 360px;
      height: 360px;
      border-radius: 50%;
      background: radial-gradient(circle at 35% 40%, #e8d5c0, #c9a98c 50%, #a07860);
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      box-shadow: 0 30px 80px rgba(61,43,31,0.15);
    }

    .hero-orb::before {
      content: '';
      position: absolute;
      inset: -30px;
      border-radius: 50%;
      border: 1px solid rgba(138,158,136,0.3);
    }

    .hero-orb::after {
      content: '';
      position: absolute;
      inset: -60px;
      border-radius: 50%;
      border: 1px solid rgba(138,158,136,0.15);
    }

    .hero-orb-inner {
      font-family: 'Cormorant Garamond', serif;
      font-size: 72px;
      font-style: italic;
      color: rgba(255,255,255,0.7);
      font-weight: 300;
    }

    .hero-badge {
      position: absolute;
      bottom: 60px;
      left: 60px;
      background: var(--warm-white);
      padding: 16px 20px;
      font-size: 11px;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      box-shadow: 0 8px 24px rgba(61,43,31,0.08);
    }

    .hero-badge strong {
      display: block;
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 400;
      color: var(--warm-brown);
      margin-bottom: 2px;
    }

    /* ── MARQUEE ── */
    .marquee-bar {
      background: var(--warm-brown);
      color: var(--cream);
      padding: 14px 0;
      overflow: hidden;
    }

    .marquee-track {
      display: flex;
      gap: 48px;
      animation: marquee 20s linear infinite;
      white-space: nowrap;
    }

    .marquee-track span {
      font-size: 11px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      opacity: 0.85;
      flex-shrink: 0;
    }

    .marquee-dot {
      color: var(--terracotta);
      opacity: 1 !important;
    }

    @keyframes marquee {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
    }

    /* ── SECTIONS ── */
    section { padding: 100px 80px; }

    .section-label {
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 16px;
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(38px, 4vw, 58px);
      font-weight: 300;
      line-height: 1.1;
      color: var(--warm-brown);
      margin-bottom: 20px;
    }

    .section-title em { font-style: italic; color: var(--terracotta); }

    .section-body {
      font-size: 15px;
      color: var(--text-muted);
      max-width: 520px;
      line-height: 1.8;
    }

    /* ── PRODUCTS ── */
    #products { background: var(--warm-white); }

    .products-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      margin-bottom: 56px;
    }

    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 24px;
    }

    .product-card {
      cursor: pointer;
      transition: transform 0.3s;
    }

    .product-card:hover { transform: translateY(-4px); }

    .product-img {
      width: 100%;
      aspect-ratio: 3/4;
      background: var(--light-tan);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 20px;
      position: relative;
      overflow: hidden;
    }

    .product-img::after {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--cream);
      opacity: 0;
      transition: opacity 0.3s;
    }

    .product-card:hover .product-img::after { opacity: 0.1; }

    .product-visual {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 8px;
    }

    .product-jar {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }

    .product-jar-label {
      font-family: 'Cormorant Garamond', serif;
      font-size: 11px;
      letter-spacing: 0.1em;
      color: rgba(255,255,255,0.8);
      font-style: italic;
    }

    .product-tag {
      font-size: 10px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--sage);
      margin-bottom: 6px;
    }

    .product-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 400;
      color: var(--warm-brown);
      margin-bottom: 6px;
    }

    .product-desc {
      font-size: 13px;
      color: var(--text-muted);
      margin-bottom: 14px;
      line-height: 1.6;
    }

    .product-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }

    .product-price {
      font-size: 16px;
      font-weight: 500;
      color: var(--warm-brown);
    }

    .product-add {
      font-size: 11px;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: var(--text-muted);
      background: none;
      border: 1px solid var(--mid-tan);
      padding: 7px 14px;
      cursor: pointer;
      transition: all 0.2s;
    }

    .product-add:hover {
      border-color: var(--warm-brown);
      color: var(--warm-brown);
    }

    /* ── INGREDIENTS ── */
    #ingredients {
      background: var(--cream);
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
      padding: 100px 80px;
    }

    .ingredients-left .section-body { margin-bottom: 48px; }

    .ingredient-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }

    .ingredient-item {
      display: flex;
      gap: 24px;
      align-items: flex-start;
      padding: 24px 0;
      border-bottom: 1px solid var(--light-tan);
    }

    .ingredient-item:first-child { border-top: 1px solid var(--light-tan); }

    .ingredient-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 14px;
      color: var(--terracotta);
      font-style: italic;
      flex-shrink: 0;
      padding-top: 2px;
      width: 24px;
    }

    .ingredient-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 400;
      color: var(--warm-brown);
      margin-bottom: 4px;
    }

    .ingredient-desc {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.65;
    }

    .ingredients-right {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    .ingredient-card {
      background: var(--light-tan);
      padding: 32px 24px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .ingredient-card:nth-child(2) { background: var(--mid-tan); margin-top: 32px; }
    .ingredient-card:nth-child(3) { background: var(--warm-white); }
    .ingredient-card:nth-child(4) { background: #ddd0c2; margin-top: -32px; }

    .ingredient-emoji { font-size: 28px; }

    .ingredient-card-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 20px;
      color: var(--warm-brown);
    }

    .ingredient-card-desc {
      font-size: 12px;
      color: var(--text-muted);
      line-height: 1.6;
    }

    /* ── ABOUT ── */
    #about {
      background: var(--warm-brown);
      color: var(--cream);
      text-align: center;
      padding: 120px 80px;
      position: relative;
      overflow: hidden;
    }

    #about::before {
      content: 'PETAL';
      position: absolute;
      font-family: 'Cormorant Garamond', serif;
      font-size: 280px;
      font-weight: 300;
      color: rgba(255,255,255,0.03);
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      white-space: nowrap;
      pointer-events: none;
    }

    .about-inner {
      max-width: 760px;
      margin: 0 auto;
      position: relative;
      z-index: 1;
    }

    .about-label {
      font-size: 11px;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: rgba(196,115,79,0.9);
      margin-bottom: 24px;
    }

    .about-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(42px, 5vw, 72px);
      font-weight: 300;
      line-height: 1.1;
      color: var(--cream);
      margin-bottom: 28px;
    }

    .about-title em { font-style: italic; color: rgba(232,213,192,0.8); }

    .about-body {
      font-size: 16px;
      line-height: 1.85;
      color: rgba(247,243,238,0.65);
      margin-bottom: 48px;
    }

    .about-stats {
      display: flex;
      justify-content: center;
      gap: 64px;
      margin-top: 64px;
      padding-top: 48px;
      border-top: 1px solid rgba(255,255,255,0.1);
    }

    .stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 48px;
      font-weight: 300;
      color: var(--cream);
      display: block;
    }

    .stat-label {
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: rgba(247,243,238,0.45);
    }

    /* ── NEWSLETTER ── */
    .newsletter {
      background: var(--light-tan);
      padding: 80px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 48px;
    }

    .newsletter-text .section-title { font-size: 36px; margin-bottom: 8px; }
    .newsletter-text .section-body { font-size: 14px; }

    .newsletter-form {
      display: flex;
      gap: 12px;
      flex-shrink: 0;
    }

    .newsletter-form input {
      background: var(--warm-white);
      border: 1px solid var(--mid-tan);
      padding: 14px 20px;
      font-family: 'Inter', sans-serif;
      font-size: 14px;
      color: var(--warm-brown);
      width: 280px;
      outline: none;
      transition: border-color 0.2s;
    }

    .newsletter-form input:focus { border-color: var(--warm-brown); }
    .newsletter-form input::placeholder { color: var(--text-muted); }

    /* ── FOOTER ── */
    footer {
      background: var(--warm-white);
      padding: 60px 80px 40px;
      border-top: 1px solid var(--light-tan);
    }

    .footer-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 48px;
    }

    .footer-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 32px;
      font-weight: 300;
      letter-spacing: 0.2em;
      color: var(--warm-brown);
    }

    .footer-tagline {
      font-size: 13px;
      color: var(--text-muted);
      margin-top: 8px;
    }

    .footer-cols {
      display: flex;
      gap: 64px;
    }

    .footer-col h4 {
      font-size: 11px;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--warm-brown);
      margin-bottom: 20px;
    }

    .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }

    .footer-col a {
      font-size: 13px;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-col a:hover { color: var(--warm-brown); }

    .footer-bottom {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding-top: 32px;
      border-top: 1px solid var(--light-tan);
      font-size: 12px;
      color: var(--text-muted);
    }

    .footer-social { display: flex; gap: 20px; }

    .footer-social a {
      font-size: 12px;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      text-decoration: none;
      transition: color 0.2s;
    }

    .footer-social a:hover { color: var(--warm-brown); }

    /* ── RESPONSIVE ── */
    @media (max-width: 1024px) {
      nav { padding: 18px 32px; }
      section { padding: 80px 40px; }
      .hero { grid-template-columns: 1fr; }
      .hero-left { padding: 60px 40px; }
      .hero-right { min-height: 500px; }
      .product-grid { grid-template-columns: repeat(2, 1fr); }
      #ingredients { grid-template-columns: 1fr; padding: 80px 40px; }
      .newsletter { flex-direction: column; padding: 60px 40px; }
      footer { padding: 48px 40px 32px; }
      .footer-top { flex-direction: column; gap: 40px; }
    }

    @media (max-width: 640px) {
      nav { padding: 16px 20px; }
      .nav-links { display: none; }
      section { padding: 60px 24px; }
      .hero-left { padding: 48px 24px; }
      .product-grid { grid-template-columns: 1fr; }
      .ingredients-right { grid-template-columns: 1fr; }
      .about-stats { flex-direction: column; gap: 32px; align-items: center; }
      .newsletter-form { flex-direction: column; width: 100%; }
      .newsletter-form input { width: 100%; }
      footer { padding: 40px 24px 28px; }
      .footer-cols { flex-direction: column; gap: 32px; }
      .footer-bottom { flex-direction: column; gap: 16px; text-align: center; }
    }
  </style>
</head>
